# oaiorchestrator environment configuration
# The runner reads process.env directly (no dotenv). In PowerShell:
#   $env:OPENAI_API_KEY = "sk-..."

# Required for real runs (dry-run / MockAgentRunner need no key)
OPENAI_API_KEY=

# Optional overrides
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Auth header style: "bearer" (default) or "api-key" / "azure".
# Auto-detected as api-key for *.azure.com endpoints when unset.
OPENAI_AUTH_STYLE=

# Optional: path to a host-side installer verification script used by the
# research-installer example workflow (see src/examples/research-installer.workflow.yaml)
ORCH_VERIFY_SCRIPT=
